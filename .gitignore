# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

node_modules
dist
dist-ssr
*.local

# Environment variables
.env
.env.*
!.env.example

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store

# Cowork / Claude local plugin cache — never belongs in the repo
.claude/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.vercel
.env*

# Vite/Vitest regenerate a temp compiled copy of the config on every run when
# the config uses ESM — these are build noise, never source.
vite.config.ts.timestamp-*.mjs
vitest.config.ts.timestamp-*.mjs

# Scratch/verification files agents sometimes leave behind when diffing a
# local file against the live deployed source before pushing.
*.deploy_reconstructed.ts
*_deploy_scratch_reconstructed.ts
