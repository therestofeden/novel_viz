# Copy to .env and fill in from your Supabase project (Settings → API).
# These are client-side (publishable) values — safe for the browser, but
# keep your real .env out of git anyway.
VITE_SUPABASE_PROJECT_ID=your-project-ref
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx_or_legacy_anon_key
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
